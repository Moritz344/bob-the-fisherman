{
  "name": "bob-the-fisherman",
  "version": "0.0.185",
  "main": "main.js",
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && npm run electron-dev\"",
    "electron-dev": "cross-env ELECTRON_DEV=true electron .",
    "build": "ng build",
    "build:electron": "ng build && electron-builder --linux AppImage",
    "electron-prod": "ng build && electron .",
    "release": "standard-version"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.8.1",
    "electron-store": "^11.0.2",
    "minecraft-data": "^3.110.2",
    "mineflayer": "^4.37.1",
    "mineflayer-pathfinder": "^2.4.5",
    "prismarine-auth": "^3.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "wait-on": "^9.0.10"
  },
  "devDependencies": {
    "@angular/build": "^21.0.2",
    "@angular/cli": "^21.0.2",
    "@angular/compiler-cli": "^21.0.0",
    "jsdom": "^27.1.0",
    "standard-version": "^9.5.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
